{
  "name": "@jeiwinfrey/chatcn",
  "version": "0.1.0",
  "description": "Scaffold AI chatbot templates into your shadcn project",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeiwinfrey/chatcn.git"
  },
  "homepage": "https://github.com/jeiwinfrey/chatcn#readme",
  "bugs": {
    "url": "https://github.com/jeiwinfrey/chatcn/issues"
  },
  "author": "Jei Winfrey",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "chatcn": "dist/index.js"
  },
  "files": [
    "dist",
    "CONTRIBUTING.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:install": "./test-global-install.sh",
    "test:commands": "./test-cli-commands.sh",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "fast-glob": "^3.3.3",
    "kleur": "^4.1.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "shadcn",
    "chatbot",
    "ai",
    "cli",
    "scaffold"
  ],
  "license": "MIT"
}
