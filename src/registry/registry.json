{
  "templates": [
    {
      "name": "chatbot-basic",
      "description": "Pick this if you are building a simple chatbot and want the smallest starting point.",
      "shadcnDeps": ["button", "input", "scroll-area"],
      "files": [
        {
          "path": "{{components}}/chat.tsx",
          "from": "templates/chatbot-basic/chat.tsx",
          "type": "ui"
        },
        {
          "path": "{{components}}/markdown-content.tsx",
          "from": "templates/chatbot-basic/markdown-content.tsx",
          "type": "ui"
        },
        {
          "path": "{{hooks}}/use-chat.ts",
          "from": "templates/chatbot-basic/use-chat.ts",
          "type": "hook"
        }
      ],
      "requiresBackend": true
    },
    {
      "name": "chatbot-ui",
      "description": "Pick this if you want a polished chatbot UI with message bubbles, markdown, and loading states.",
      "shadcnDeps": ["button", "input", "scroll-area", "card", "avatar", "skeleton"],
      "files": [
        {
          "path": "{{components}}/chat.tsx",
          "from": "templates/chatbot-ui/chat.tsx",
          "type": "ui"
        },
        {
          "path": "{{components}}/chat-message.tsx",
          "from": "templates/chatbot-ui/chat-message.tsx",
          "type": "ui"
        },
        {
          "path": "{{components}}/markdown-content.tsx",
          "from": "templates/chatbot-ui/markdown-content.tsx",
          "type": "ui"
        },
        {
          "path": "{{hooks}}/use-chat.ts",
          "from": "templates/chatbot-ui/use-chat.ts",
          "type": "hook"
        }
      ],
      "requiresBackend": true
    },
    {
      "name": "chatbot-assistant",
      "description": "Pick this if you are building a reusable assistant and want cleaner separation between UI, hook, and LLM logic.",
      "shadcnDeps": ["button", "input", "scroll-area", "card", "separator"],
      "files": [
        {
          "path": "{{components}}/assistant.tsx",
          "from": "templates/chatbot-assistant/assistant.tsx",
          "type": "ui"
        },
        {
          "path": "{{components}}/assistant-message.tsx",
          "from": "templates/chatbot-assistant/assistant-message.tsx",
          "type": "ui"
        },
        {
          "path": "{{components}}/markdown-content.tsx",
          "from": "templates/chatbot-assistant/markdown-content.tsx",
          "type": "ui"
        },
        {
          "path": "{{hooks}}/use-assistant.ts",
          "from": "templates/chatbot-assistant/use-assistant.ts",
          "type": "hook"
        }
      ],
      "requiresBackend": true
    },
    {
      "name": "chatbot-support",
      "description": "Pick this if you are building a support or helpdesk chatbot with quick replies and a guided tone.",
      "shadcnDeps": ["button", "input", "scroll-area", "card", "badge"],
      "files": [
        {
          "path": "{{components}}/support-chat.tsx",
          "from": "templates/chatbot-support/support-chat.tsx",
          "type": "ui"
        },
        {
          "path": "{{components}}/markdown-content.tsx",
          "from": "templates/chatbot-support/markdown-content.tsx",
          "type": "ui"
        },
        {
          "path": "{{hooks}}/use-support-chat.ts",
          "from": "templates/chatbot-support/use-support-chat.ts",
          "type": "hook"
        }
      ],
      "requiresBackend": true
    }
  ],
  "providers": [
    {
      "name": "openai",
      "label": "OpenAI",
      "env": ["OPENAI_API_KEY"],
      "baseURL": "https://api.openai.com/v1",
      "defaultModel": "gpt-5-mini",
      "anthropicFormat": false,
      "googleFormat": false,
      "bedrockFormat": false
    },
    {
      "name": "anthropic",
      "label": "Anthropic (Claude)",
      "env": ["ANTHROPIC_API_KEY"],
      "baseURL": "https://api.anthropic.com/v1",
      "defaultModel": "claude-3-5-haiku-latest",
      "anthropicFormat": true,
      "googleFormat": false,
      "bedrockFormat": false
    },
    {
      "name": "openrouter",
      "label": "OpenRouter",
      "env": ["OPENROUTER_API_KEY"],
      "baseURL": "https://openrouter.ai/api/v1",
      "defaultModel": "openrouter/auto",
      "anthropicFormat": false,
      "googleFormat": false,
      "bedrockFormat": false
    },
    {
      "name": "google",
      "label": "Google Gemini",
      "env": ["GOOGLE_API_KEY"],
      "baseURL": "https://generativelanguage.googleapis.com/v1beta",
      "defaultModel": "gemini-2.5-flash-lite",
      "anthropicFormat": false,
      "googleFormat": true,
      "bedrockFormat": false
    },
    {
      "name": "aws-bedrock",
      "label": "AWS Bedrock",
      "env": ["AWS_REGION", "AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY"],
      "defaultModel": "anthropic.claude-haiku-4-5-20251001-v1:0",
      "anthropicFormat": false,
      "googleFormat": false,
      "bedrockFormat": true
    },
    {
      "name": "groq",
      "label": "Groq",
      "env": ["GROQ_API_KEY"],
      "baseURL": "https://api.groq.com/openai/v1",
      "defaultModel": "meta-llama/llama-4-scout-17b-16e-instruct",
      "anthropicFormat": false,
      "googleFormat": false,
      "bedrockFormat": false
    },
    {
      "name": "together",
      "label": "Together AI",
      "env": ["TOGETHER_API_KEY"],
      "baseURL": "https://api.together.xyz/v1",
      "defaultModel": "deepseek-ai/DeepSeek-V3.1",
      "anthropicFormat": false,
      "googleFormat": false,
      "bedrockFormat": false
    },
    {
      "name": "mistral",
      "label": "Mistral",
      "env": ["MISTRAL_API_KEY"],
      "baseURL": "https://api.mistral.ai/v1",
      "defaultModel": "mistral-small-latest",
      "anthropicFormat": false,
      "googleFormat": false,
      "bedrockFormat": false
    },
    {
      "name": "xai",
      "label": "xAI (Grok)",
      "env": ["XAI_API_KEY"],
      "baseURL": "https://api.x.ai/v1",
      "defaultModel": "grok-4.20-beta-latest-non-reasoning",
      "anthropicFormat": false,
      "googleFormat": false,
      "bedrockFormat": false
    },
    {
      "name": "deepseek",
      "label": "DeepSeek",
      "env": ["DEEPSEEK_API_KEY"],
      "baseURL": "https://api.deepseek.com/v1",
      "defaultModel": "deepseek-chat",
      "anthropicFormat": false,
      "googleFormat": false,
      "bedrockFormat": false
    },
    {
      "name": "cerebras",
      "label": "Cerebras",
      "env": ["CEREBRAS_API_KEY"],
      "baseURL": "https://api.cerebras.ai/v1",
      "defaultModel": "gpt-oss-120b",
      "anthropicFormat": false,
      "googleFormat": false,
      "bedrockFormat": false
    },
    {
      "name": "fireworks",
      "label": "Fireworks AI",
      "env": ["FIREWORKS_API_KEY"],
      "baseURL": "https://api.fireworks.ai/inference/v1",
      "defaultModel": "accounts/fireworks/models/kimi-k2-thinking",
      "anthropicFormat": false,
      "googleFormat": false,
      "bedrockFormat": false
    }
  ]
}
